{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".git",
      ".idea",
      "readme",
      "node_modules"
    ]
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "disallowLegacyRuntimeConfig": true,
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ]
}
